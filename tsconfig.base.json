{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@onscreen/core": ["packages/core/src/index.ts"],
      "@onscreen/template-library": ["packages/template-library/src/index.ts"],
      "@onscreen/renderer": ["packages/renderer/src/index.ts"]
    }
  }
}
