{
  "name": "onscreen-graphics-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "onscreen-graphics-monorepo",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.6.3"
      }
    },
    "apps/web": {
      "name": "@onscreen/web",
      "version": "0.1.0",
      "dependencies": {
        "@onscreen/core": "0.1.0",
        "@onscreen/template-library": "0.1.0"
      }
    },
    "node_modules/@onscreen/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@onscreen/renderer": {
      "resolved": "packages/renderer",
      "link": true
    },
    "node_modules/@onscreen/template-library": {
      "resolved": "packages/template-library",
      "link": true
    },
    "node_modules/@onscreen/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/core": {
      "name": "@onscreen/core",
      "version": "0.1.0"
    },
    "packages/renderer": {
      "name": "@onscreen/renderer",
      "version": "0.1.0",
      "dependencies": {
        "@onscreen/core": "0.1.0"
      }
    },
    "packages/template-library": {
      "name": "@onscreen/template-library",
      "version": "0.1.0",
      "dependencies": {
        "@onscreen/core": "0.1.0"
      }
    }
  }
}
